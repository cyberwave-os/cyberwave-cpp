@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

find_dependency(cpprestsdk REQUIRED)
find_dependency(OpenSSL REQUIRED)

# Restore build-time feature flags.
include("${CMAKE_CURRENT_LIST_DIR}/CyberwaveCppSDKBuildConfig.cmake")

if(CYBERWAVE_SDK_HAS_FFMPEG)
    find_dependency(PkgConfig REQUIRED)
    pkg_check_modules(FFMPEG REQUIRED IMPORTED_TARGET libavcodec libavutil libswscale)
endif()

if(CYBERWAVE_SDK_HAS_WEBRTC)
    find_dependency(Threads REQUIRED)
    find_dependency(LibDataChannel REQUIRED)
endif()

include("${CMAKE_CURRENT_LIST_DIR}/CyberwaveCppSDKTargets.cmake")
